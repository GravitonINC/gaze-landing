---
// For Watchers — Section 4
// Copy and design spec will be delivered by Ember and Designer
---

<section
  id="for-watchers"
  class="py-[var(--spacing-section-lg)]"
  aria-label="For Watchers"
>
  <div class="section-container">
    <div class="divider mb-[var(--spacing-section-md)]"></div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Visual placeholder — Designer will spec -->
      <div
        class="aspect-square rounded-[var(--radius-card)] bg-gaze-bg-surface border border-gaze-border animate-on-scroll flex items-center justify-center order-last lg:order-first"
        aria-hidden="true"
      >
        <p class="text-body-sm text-gaze-fg-subtle">Visual — Designer spec pending</p>
      </div>

      <!-- Copy -->
      <div class="animate-on-scroll">
        <p class="text-label-md uppercase tracking-widest text-gaze-ember mb-4">
          For Watchers
        </p>
        <h2 class="text-display-md font-medium text-gaze-fg-primary mb-6">
          Watch. Earn. Keep watching.
        </h2>
        <p class="text-body-xl text-gaze-fg-secondary mb-8">
          Install the Chrome extension. Watch on any of nine platforms.
          Your attention earns — no cost, no tokens, no daily check-ins.
        </p>
        <ul class="space-y-4">
          {[
            'Free to start — no SOL, no tokens required',
            'Works on YouTube, Twitch, Kick, Rumble, X, and more',
            'Runs silently in the background',
            'Stake to earn 9× leaderboard weight for your favorite creators',
          ].map((item) => (
            <li class="flex items-start gap-3 text-body-md text-gaze-fg-secondary">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-gaze-ember flex-shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
