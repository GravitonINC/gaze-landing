---
// The Protocol — Section 6
// On-chain mechanics overview — transparent, factual, no hype
---

const stats = [
  { label: 'Programs', value: '4', description: 'On-chain Solana programs' },
  { label: 'Platforms', value: '9', description: 'Supported streaming platforms' },
  { label: 'Multiplier', value: '9×', description: 'Leaderboard weight for stakers who watch' },
] as const;
---

<section
  id="the-protocol"
  class="py-[var(--spacing-section-lg)]"
  aria-label="The Protocol"
>
  <div class="section-container">
    <div class="divider mb-[var(--spacing-section-md)]"></div>

    <div class="max-w-narrow mb-16 animate-on-scroll">
      <p class="text-label-md uppercase tracking-widest text-gaze-ember mb-4">
        The Protocol
      </p>
      <h2 class="text-display-md font-medium text-gaze-fg-primary mb-6">
        On-chain means accountable.
      </h2>
      <p class="text-body-xl text-gaze-fg-secondary">
        Four Solana programs. Every bonding curve, every trade, every stake,
        every claim — on-chain, auditable, permanent.
        The protocol cannot hide what it does because the ledger is public.
      </p>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      {stats.map(({ label, value, description }) => (
        <div
          class="
            p-8
            rounded-[var(--radius-card)]
            bg-gaze-bg-surface
            border border-gaze-border
            animate-on-scroll
          "
        >
          <p class="text-display-lg font-medium text-gaze-fg-primary mb-2">{value}</p>
          <p class="text-body-md font-medium text-gaze-fg-primary mb-1">{label}</p>
          <p class="text-body-sm text-gaze-fg-muted">{description}</p>
        </div>
      ))}
    </div>

    <!-- Program addresses -->
    <div
      class="
        p-8
        rounded-[var(--radius-card)]
        bg-gaze-bg-surface
        border border-gaze-border
        animate-on-scroll
      "
    >
      <p class="text-label-md uppercase tracking-widest text-gaze-fg-muted mb-6">
        On-Chain Programs
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          { name: 'Tokens',   address: 'XEENqbVXt8y94cH7WMwYyQSuDgkvzZTzEzpsWLZu7Jf' },
          { name: 'Voter',    address: 'XNGVXFcvqTM7ET3kwztFskFBmygQFXQVRQVBKp5Frvm' },
          { name: 'Lend',     address: 'LENDcjsxpmVPrAG9nYp6hbQDVcsFjsaaPcRQow5W8te' },
          { name: 'Payments', address: 'BkWxgtCSpwBwrL7aBmAtM5i76ZmZLS3otc3D4ShLbJV9' },
        ].map(({ name, address }) => (
          <div class="flex flex-col gap-1">
            <p class="text-label-sm uppercase tracking-widest text-gaze-fg-muted">{name}</p>
            <p class="font-mono text-body-sm text-gaze-fg-secondary break-all">{address}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
