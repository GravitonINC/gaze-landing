---
// CTA — Call-to-action section (install extension + launch app)
---

<section
  id="cta"
  class="relative py-[var(--spacing-section-xl)] bg-gaze-bg-base overflow-hidden"
  aria-labelledby="cta-heading"
>
  <!-- Amber radial glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] rounded-full"
      style="background: radial-gradient(ellipse at center, rgba(232,98,42,0.12) 0%, rgba(232,98,42,0.04) 40%, transparent 70%)"
    ></div>
  </div>

  <div class="section-container relative z-10">
    <div class="flex flex-col items-center text-center gap-6">

      <!-- BurningEye small icon -->
      <div class="eye-icon-wrapper mb-2 animate-on-scroll" aria-hidden="true">
        <svg
          class="eye-icon"
          viewBox="0 0 200 200"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- Eye shape -->
          <path
            d="M10 100 C40 50, 160 50, 190 100 C160 150, 40 150, 10 100Z"
            fill="#1a1a1a"
            stroke="rgba(255,191,0,0.5)"
            stroke-width="2"
          />
          <!-- Iris -->
          <circle cx="100" cy="100" r="38" fill="url(#ctaIrisGradient)" class="iris" />
          <!-- Pupil -->
          <circle cx="100" cy="100" r="18" fill="#0a0a0a" />
          <!-- Pupil inner light -->
          <circle cx="108" cy="92" r="5" fill="rgba(255,191,0,0.7)" />

          <defs>
            <radialGradient id="ctaIrisGradient" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#FFBF00" stop-opacity="0.9" />
              <stop offset="60%" stop-color="#CC9900" stop-opacity="0.7" />
              <stop offset="100%" stop-color="#664400" stop-opacity="0.5" />
            </radialGradient>
          </defs>
        </svg>
      </div>

      <h2
        id="cta-heading"
        class="text-display-md font-medium text-gaze-fg-primary max-w-2xl animate-on-scroll"
        style="animation-delay: 100ms"
      >
        Your attention is already valuable.
      </h2>

      <p class="text-body-lg text-gaze-fg-secondary max-w-prose animate-on-scroll" style="animation-delay: 150ms">
        Gaze makes that visible. Install the extension, watch what you watch, earn every second.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4 mt-4 animate-on-scroll" style="animation-delay: 200ms">
        <a
          href="#"
          class="
            inline-flex items-center gap-2
            px-8 py-4
            text-body-md font-medium
            bg-gaze-ember text-white
            rounded-pill
            transition-all duration-[var(--duration-base)] ease-[var(--ease-gaze)]
            hover:bg-gaze-ember-dim
          "
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="4" fill="currentColor" />
            <path d="M12 8h8.5M6.5 20.5L10.5 14M17.5 20.5L13.5 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" />
          </svg>
          Install Chrome Extension
        </a>
        <a
          href="https://app.gazeprotocol.com/launch"
          target="_blank"
          rel="noopener noreferrer"
          class="
            inline-flex items-center gap-2
            px-8 py-4
            text-body-md font-medium
            text-gaze-fg-secondary
            border border-gaze-border
            rounded-pill
            transition-all duration-[var(--duration-base)] ease-[var(--ease-gaze)]
            hover:border-gaze-ember hover:text-gaze-fg-primary
          "
        >
          Launch a Token
        </a>
        <a
          href="https://app.gazeprotocol.com/creators"
          target="_blank"
          rel="noopener noreferrer"
          class="
            text-body-md
            text-gaze-fg-muted
            transition-colors duration-[var(--duration-base)]
            hover:text-gaze-ember
          "
        >
          Explore Creators &rarr;
        </a>
      </div>

      <p class="text-body-xs text-gaze-fg-subtle animate-on-scroll" style="animation-delay: 250ms">
        Free to install. No tokens required to start watching.
      </p>

    </div>
  </div>
</section>

<style>
  .eye-icon-wrapper {
    width: 80px;
    height: 80px;
  }

  .eye-icon {
    width: 100%;
    height: 100%;
  }

  .iris {
    animation: irisPulse 4s ease-in-out infinite;
    transform-origin: center;
  }

  @keyframes irisPulse {
    0%, 100% { opacity: 0.85; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.08); }
  }

  @media (max-width: 768px) {
    .eye-icon-wrapper {
      width: 64px;
      height: 64px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .iris {
      animation: none;
    }
  }
</style>
